#include <stdio.h>

int main() {
    //INPUT SECTION
    char name[50];
    int age;
    int score;
    int option;
    
    printf("Enter Name: ");
    scanf("%s", name);
    printf("Enter Age: ");
    scanf("%d", &age);
    printf("Enter Score: ");
    scanf("%d", &score);
    
    //MENU SECTION
    printf("\n--- MENU ---\n");
    printf("1. Show Profile\n");
    printf("2. Show Result\n");
    printf("3. Exit\n");
    printf("Choose option: ");
    scanf("%d", &option);
    
    //CONTROL SECTION
    switch(option) {
        
        case 1:
        printf("\nNAME: %s\n", name);
        printf("AGE: %d\n", age);
        printf("SCORE: %d\n", score);
        break;
        
        //LOGIC SECTION
        case 2:
        if(score>100 || score<0){
            printf("INVALID\n");
        }
        if(score>=80) {
            printf("EXCELLENT\n");
        }
        else if(score>=50) {
            printf("PASS\n");
        }
        else {
            printf("FAIL\n");
        }
        break;
        
        case 3:
        printf("Good Bye\n");
        break;
        default:
        printf("Invalid Option\n");
    }
    return 0;
}
    
    